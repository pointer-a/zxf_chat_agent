# ZXF Dialogue Agent — 环境变量配置
# 复制为 .env 后修改 API_KEY 即可运行
# 与 MokioAgent 共享同一个 .env，变量名完全兼容

# ── API 密钥（与 MokioAgent 兼容的变量名）──
API_KEY=sk-your-deepseek-api-key
MODEL=deepseek-v4-flash
BASE_URL=https://api.deepseek.com/v1

# ── 也支持 DEEPSEEK_ 前缀（优先级更高）──
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── 数据库 ──
DATABASE_URL=sqlite+aiosqlite:///./data/chat.db?timeout=15

# ── 服务器 ──
HOST=0.0.0.0
PORT=8000
DEBUG=false
