# ZXF Dialogue Agent — 环境变量配置
# 复制为 .env 后修改 DEEPSEEK_API_KEY 即可运行

# ── DeepSeek API（必填）──
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ── DeepSeek API 地址（通常不用改）──
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── 数据库 ──
DATABASE_URL=sqlite+aiosqlite:///./data/chat.db?timeout=15

# ── 服务器 ──
HOST=0.0.0.0
PORT=8000
DEBUG=false
